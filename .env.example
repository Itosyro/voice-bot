# ============================================================================
# Telegram
# ============================================================================
TELEGRAM_BOT_TOKEN=                    # от @BotFather

# Список разрешённых user_id через запятую. Пусто = открыто для всех.
ALLOWED_USER_IDS=

# user_id админа (один или через запятую). Имеет доступ к /sync_skills, /stats.
ADMIN_USER_IDS=

# ============================================================================
# Groq API ключи — ОТДЕЛЬНЫЙ КЛЮЧ НА КАЖДЫЙ РЕЖИМ
# Регистрация (бесплатно): https://console.groq.com
# ============================================================================
GROQ_API_KEY_POLISH=
GROQ_API_KEY_PROMPT=
GROQ_API_KEY_HUMANIZER=
GROQ_API_KEY_TRANSLATOR=

# Fallback ключ — используется если ключ для конкретного режима не задан.
# Опционально, но рекомендуется.
GROQ_API_KEY_FALLBACK=

# ============================================================================
# Модели
# ============================================================================
LLM_MODEL_DEFAULT=llama-3.3-70b-versatile
LLM_MODEL_FAST=llama-3.1-8b-instant
# Строгий режим для Coder Strict.
# Бесплатный вариант (рекомендуем): openai/gpt-oss-120b (доступна на Free тире Groq)
# Платный (ещё лучше): moonshotai/kimi-k2-instruct (только на Developer plan)
LLM_MODEL_STRICT=openai/gpt-oss-120b
WHISPER_MODEL=whisper-large-v3

# ============================================================================
# PostgreSQL
# ============================================================================
# Внутри docker-compose: postgres://postgres:postgres@db:5432/voicebot
# Локально dev: postgres://postgres:postgres@localhost:5432/voicebot
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/voicebot

# ============================================================================
# Лимиты и поведение
# ============================================================================
MAX_VOICE_DURATION_SEC=3600        # 1 час абсолютный максимум
CHUNK_THRESHOLD_SEC=600            # выше — chunked-pipeline
CHUNK_DURATION_SEC=300             # длина одного чанка (5 мин)
CHUNK_THROTTLE_SEC=1.5             # пауза между Groq-вызовами

# Retention / cleanup (фоновая задача удаляет старые строки из БД)
TRANSCRIPTION_CACHE_TTL_DAYS=1     # удалять кэш транскриптов старше N дней (0 — выкл.)
REQUEST_HISTORY_TTL_DAYS=30        # удалять историю запросов старше N дней (0 — выкл.)
CLEANUP_INTERVAL_HOURS=24          # как часто запускать cleanup
CLEANUP_INITIAL_DELAY_SEC=300      # пауза перед первым запуском после старта
MAX_TEXT_LENGTH=10000
RATE_LIMIT_PER_USER_PER_MIN=20

# Кеш транскрипций — пропускать Whisper при повторной отправке того же файла
ENABLE_TRANSCRIPTION_CACHE=true

# ============================================================================
# Skills
# ============================================================================
SKILLS_AUTO_SYNC_ON_STARTUP=true
SKILLS_SYNC_INTERVAL_HOURS=168     # 1 раз в неделю

# ============================================================================
# Логи
# ============================================================================
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                    # json | text

# ============================================================================
# Прочее
# ============================================================================
TZ=UTC
